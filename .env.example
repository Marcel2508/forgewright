# Copy to `.env` next to docker-compose.yml and fill in what you need.
# Anything unset here falls back to the defaults in docker-compose.yml.

# --- Platform (GitLab or GitHub) ---------------------------------------------
# Personal Access Token for the bot account.
# (You can also put `platform_token:` in config.yaml instead.)
PLATFORM_TOKEN=

# --- Webhook ------------------------------------------------------------------
# Shared secret used to validate incoming webhook requests.
WEBHOOK_SECRET=
# Port on the host. Bind address defaults to 127.0.0.1 (localhost only) —
# set to 0.0.0.0 if you're terminating TLS in front of it.
WEBHOOK_PORT=5000
WEBHOOK_BIND=127.0.0.1

# --- Poller schedule (supercronic cron expression) ---------------------------
# Standard 5-field cron. Default: every 5 minutes.
POLL_SCHEDULE=*/5 * * * *

# --- Claude auth (only used by the `claude` profile) -------------------------
# Option A — Pro/Max subscription. Point CLAUDE_HOME at the host home of a
# user who has already run `claude login`. It must contain BOTH `.claude.json`
# (the OAuth session) and `.claude/` (projects, todos, settings).
# CLAUDE_HOME=/home/youruser
#
# Option B — API key. Leave CLAUDE_HOME unset (a seeded ./docker/claude-state
# dir will be used as a scratch home) and set:
ANTHROPIC_API_KEY=

# --- OpenCode config (only used by the `opencode` profile) -------------------
# Absolute path to the host's OpenCode config directory. Lets you use your
# own provider / model configuration inside the container.
# OPENCODE_CONFIG_HOME=/home/youruser/.config/opencode
