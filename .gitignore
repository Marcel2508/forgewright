.DS_Store
__pycache__/
*.pyc
*.pyo
config.yaml
venv/
.venv/
*.egg-info/
dist/
build/
.env
.claude/last-run-summary.md

# Runtime writes to the seeded claude-state dir (when running compose from a
# source checkout). The initial seed (.gitkeep and a blank .claude.json) is
# tracked; anything Claude writes on top is ignored.
docker/claude-state/.claude/*
!docker/claude-state/.claude/.gitkeep
